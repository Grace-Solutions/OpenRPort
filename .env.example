#=============================================================================
# OPENRPORT - Unified stack (Server + Pairing + UI + Binaries)
#=============================================================================
#
# CREDENTIALS:
#   API Username: admin
#   API Password: see RPORTD_API_PASSWORD below (regenerate before production)
#
# ACCESS URL: http(s)://<edge>/        (terminate TLS at the edge proxy)
#             http://<this-host>:${SERVER_API_PUBLISH_PORT}/api/v1/   (direct)
#
# PRODUCTION SETUP:
#   1. Copy this file to .env: cp .env.example .env
#   2. Regenerate every secret: openssl rand -hex 16 / openssl rand -base64 50
#   3. Set OPENRPORT_*_PUBLIC_URL to your real https URLs
#   4. Run: make prepare         (fetches agent binaries, generates configs)
#   5. Run: make up
#
#=============================================================================

# Stack Identity
STACK_NAME=stk-openrport-00001
STACK_BINDMOUNTROOT=/mnt/data/docker/stacks

# Container User/Group (0 = root; match host user for bind-mount perms)
PUID=1000
PGID=1000

# Agent binary source. "build" compiles src/Server/cmd/rport from the local
# subtree (no external dependency); "fetch" downloads upstream releases from
# github.com/openrport/openrport.
RPORT_AGENT_SOURCE=build

# Agent binary release pinned at compose-prepare time. "latest" = follow
# the most recent stable GitHub release (fetch mode) or stamp build version
# from the src/Server commit sha (build mode); otherwise pin to e.g. 0.9.10.
RPORT_VERSION=latest

# ─── Public-facing URLs ─────────────────────────────────────────────────────
# Set these to the external URLs your edge reverse proxy exposes. Leave
# blank for pure local testing (then http://<host>:<publish_port> is used).
#
# OPENRPORT_SERVER_PUBLIC_URL is the **agent connect URL** that gets baked
# into the rportd config and into install scripts (port 8081 in dev).
# OPENRPORT_SERVER_API_URL is the **browser-facing REST API URL** the UI
# fetches from (port 8080 in dev). In subpath production behind an edge
# proxy both can be the same hostname; in standalone local testing they
# differ because each port is exposed separately. Leave SERVER_API_URL
# blank in subpath mode to use relative URLs against the UI's own origin.
OPENRPORT_DEPLOYMENT_MODE=subpath
OPENRPORT_SERVER_PUBLIC_URL=
OPENRPORT_SERVER_API_URL=
OPENRPORT_PAIRING_PUBLIC_URL=
OPENRPORT_UI_PUBLIC_URL=
OPENRPORT_BINARIES_PUBLIC_URL=

# ─── Local browser testing without an edge proxy ────────────────────────────
# Uncomment to point the UI at the Server's API publish port directly.
# Server CORS already wildcards (RPORTD_CORS_ORIGINS=*) so cross-origin
# requests from <UI_PORT> -> <API_PORT> work out of the box.
# OPENRPORT_SERVER_API_URL=http://127.0.0.1:8080

# Subpath layout (only used when DEPLOYMENT_MODE=subpath)
OPENRPORT_SERVER_BASE_PATH=/
OPENRPORT_PAIRING_BASE_PATH=/pairing
OPENRPORT_UI_BASE_PATH=/ui
OPENRPORT_BINARIES_BASE_PATH=/binaries

# ─── Network bindings ───────────────────────────────────────────────────────
# All published ports are bound to this address on the host. Default 0.0.0.0
# allows an edge reverse proxy on a different node to reach this host.
# Set to 127.0.0.1 to keep traffic loopback-only.
OPENRPORT_BIND_ADDRESS=0.0.0.0

# ─── Per-service ports ──────────────────────────────────────────────────────
# *_INTERNAL_PORT = port the service listens on inside its container.
# *_PUBLISH_PORT  = host-side port (left side of the docker-compose mapping).
# Adjust either side independently; in host-networking deployments only the
# internal port matters and PUBLISH_PORT is ignored.
SERVER_API_INTERNAL_PORT=8080
SERVER_API_PUBLISH_PORT=8080
SERVER_CLIENT_INTERNAL_PORT=8081
SERVER_CLIENT_PUBLISH_PORT=8081
PAIRING_INTERNAL_PORT=9978
PAIRING_PUBLISH_PORT=9978
UI_INTERNAL_PORT=3000
UI_PUBLISH_PORT=3000

# ─── rportd (Server) secrets ────────────────────────────────────────────────
# Replace ALL of these before exposing the stack publicly.
RPORTD_API_USER=admin
RPORTD_API_PASSWORD=2bf29018e02020ee68fa52a2c21769b3
RPORTD_KEY_SEED=0376d557285172e3ba3aa4bbddb94609a1c7
RPORTD_JWT_SECRET=MdLUhBxYSK8YqPFKIXwiuIcwga8Jept7oY9+INkecT+rvWAnSWkReu4aGk41PEB75Lo=
RPORTD_CLIENT_AUTH=clientauth1:2f1c74454170ab2e432341a5
RPORTD_CORS_ORIGINS=*

# ─── Binary delivery (offload) ──────────────────────────────────────────────
# When all three are set, FetchAgentBinaries.sh additionally uploads the
# fetched artefacts to S3 (the Pairing service still serves the local copy
# under ${OPENRPORT_BINARIES_BASE_PATH}). Presigned-URL serving is a
# follow-up wiring step in the Pairing service.
RPORT_S3_BUCKET=
RPORT_S3_REGION=
RPORT_S3_ENDPOINT=
RPORT_S3_ACCESS_KEY=
RPORT_S3_SECRET_KEY=
RPORT_S3_PRESIGN_TTL=3600

# ─── OIDC single sign-on (open-source plus plugin) ──────────────────────────
# Setting RPORT_OIDC_ISSUER_URL switches the API from Basic to OIDC auth via
# the bundled rport-plus.so (built into the Server image at
# /usr/local/lib/rport/rport-plus.so).
#
# The issuer URL may be either the issuer base or the full discovery URL --
# both are equivalent because GenerateConfig.sh fetches the discovery doc at
# config-render time and resolves authorization_endpoint, token_endpoint and
# jwks_uri from it. Examples (Authentik):
#   RPORT_OIDC_ISSUER_URL=https://auth.example.com/application/o/rport/
#   RPORT_OIDC_ISSUER_URL=https://auth.example.com/application/o/rport/.well-known/openid-configuration
# Keycloak:
#   RPORT_OIDC_ISSUER_URL=https://kc.example.com/realms/rport
#
# Set RPORT_OIDC_AUTHORIZE_URL/_TOKEN_URL/_JWKS_URL only to override what
# discovery returns or to bypass discovery when the IDP is unreachable from
# the host running GenerateConfig.sh.
RPORT_OIDC_ISSUER_URL=
RPORT_OIDC_CLIENT_ID=
RPORT_OIDC_CLIENT_SECRET=
RPORT_OIDC_REDIRECT_URI=
RPORT_OIDC_AUTHORIZE_URL=
RPORT_OIDC_TOKEN_URL=
RPORT_OIDC_JWKS_URL=
RPORT_OIDC_PROVIDER=oidc
RPORT_OIDC_USERNAME_CLAIM=preferred_username
RPORT_OIDC_PERMITTED_USER_MATCH=.*
RPORT_PLUS_PLUGIN_PATH=

# When OIDC is enabled, rportd disables the built-in /api/v1/login endpoints
# by default. Set this to true to keep the local username/password path
# reachable as a break-glass admin login (useful when the IdP is unreachable).
# The UI uses /api/v1/auth/provider.local_login_available to decide whether
# to render the basic-auth form alongside the OIDC button.
RPORT_OIDC_ALLOW_LOCAL_LOGIN=false

# UI auth-mode override. Controls how the login page renders when both
# auth mechanisms are technically available. One of:
#   auto  - follow whatever /api/v1/auth/provider says (basic xor oidc)
#   basic - force the local form (only useful with allow_local_login=true)
#   oidc  - force the OIDC button (skip the local form even if allowed)
#   both  - render both side-by-side (default; matches local_login_available)
OPENRPORT_UI_AUTH_MODE=both

# ─── Automatic updates (Watchtower) ─────────────────────────────────────────
SERVER_ENABLEAUTOMATICUPDATES=false
PAIRING_ENABLEAUTOMATICUPDATES=false
UI_ENABLEAUTOMATICUPDATES=false
