# ─────────────────────────────────────────────
# OpenRPort Unified – Environment Variables
# Copy to .env and fill in your values.
# ─────────────────────────────────────────────

# Deployment mode: dns | subpath | internal | local
OPENRPORT_DEPLOYMENT_MODE=subpath

# Public URLs (leave blank to auto-discover from headers)
OPENRPORT_SERVER_PUBLIC_URL=
OPENRPORT_PAIRING_PUBLIC_URL=
OPENRPORT_UI_PUBLIC_URL=

# Base paths (used in subpath mode)
OPENRPORT_SERVER_BASE_PATH=/
OPENRPORT_PAIRING_BASE_PATH=/pairing
OPENRPORT_UI_BASE_PATH=/ui

# Port bindings on the host
OPENRPORT_SERVER_API_PORT=8080
OPENRPORT_SERVER_CLIENT_PORT=8081
OPENRPORT_PAIRING_PORT=9978
OPENRPORT_UI_PORT=3000

# Header-based auto-discovery
OPENRPORT_AUTO_DISCOVER_PUBLIC_URL=true
OPENRPORT_TRUST_PROXY_HEADERS=true

# ─── openrport-server (rportd) ──────────────
# Admin credentials (change before first run!)
RPORTD_API_USER=admin
RPORTD_API_PASSWORD=changeme

# Static client (agent) auth used by the rportd `[server]` section.
# Format: clientID:password. rportd refuses to start without one of
# auth / auth_file / auth_table. Replace before exposing publicly.
RPORTD_CLIENT_AUTH=clientauth1:1234

# CORS – comma-separated origins, or * for dev
RPORTD_CORS_ORIGINS=*

# ─── rport-pairing ──────────────────────────
# The URL clients will use to call the pairing service
# (resolved automatically when OPENRPORT_AUTO_DISCOVER_PUBLIC_URL=true)
PAIRING_EXTERNAL_URL=

# ─── openrport-ui (Nuxt) ────────────────────
# Set to the server's public API URL; auto-resolved when blank
NUXT_API_URL=
NUXT_APP_BASE_URL=/ui
