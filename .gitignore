# Environment (never commit secrets)
.env

# Local-only reverse-proxy configs (real domains/IPs/cert paths).
# Sanitised samples live alongside as examples/<proxy>.sample.* and are tracked.
examples/nginx.local.conf
examples/Caddyfile.local
examples/haproxy.local.cfg

# Stack data (bind mounts under STACK_BINDMOUNTROOT, default-local at ./Data)
Data/

# Legacy config dir (pre-bind-mount layout)
Config/

# Docker build cache
.docker/

# OS / editor
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# Node / Nuxt (inside src/Ui – already in subtree .gitignore, belt-and-suspenders)
src/Ui/.nuxt/
src/Ui/.output/
src/Ui/node_modules/

# Go build artifacts
src/Server/rportd
src/Pairing/rport-pairing

# Go test runtime outputs (produced by `go test` in these subtrees;
# see integration_test.go / runner_test.go / test_app/test_app.go).
src/Server/server/notifications/out.json
src/Server/server/notifications/channels/scriptRunner/out.json
