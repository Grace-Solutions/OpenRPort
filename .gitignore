# Environment (never commit secrets)
.env

# Local-only reverse-proxy configs (real domains/IPs/cert paths).
# Sanitised samples live alongside as docs/<proxy>.sample.* and are tracked.
docs/nginx.local.conf
docs/Caddyfile.local
docs/haproxy.local.cfg
docs/nginx.txt

# Stack data (bind mounts under STACK_BINDMOUNTROOT, default-local at ./Data)
Data/

# Legacy config dir (pre-bind-mount layout)
Config/

# Docker build cache
.docker/

# OS / editor
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# Node / Nuxt (inside src/Ui – already in subtree .gitignore, belt-and-suspenders)
src/Ui/.nuxt/
src/Ui/.output/
src/Ui/node_modules/

# Go build artifacts
src/Server/rportd
src/Pairing/rport-pairing
