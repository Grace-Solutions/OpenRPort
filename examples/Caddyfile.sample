# OpenRPort Unified - sample Caddyfile reverse-proxy configuration
#
# Mirrors examples/nginx.sample.conf. Caddy obtains its TLS certificate from
# Let's Encrypt automatically based on the site address; supply your own
# cert with `tls /path/cert /path/key` if you do not want ACME.
#
# EXAMPLE DEPLOYMENT (matches .env.example, examples/nginx.sample.conf,
# examples/haproxy.sample.cfg, and the README topology diagrams):
#
#   Public DNS A records :  rport.example.com         -> 203.0.113.20
#                           tunnels.rport.example.com -> 203.0.113.20
#   Edge firewall / NAT  :  203.0.113.20  (public)
#                           tcp/443             -> 10.0.0.4:443     (this proxy)
#                           tcp+udp/38200-38400 -> 10.0.0.5:38200-* (stack VM)
#   This proxy host      :  10.0.0.4
#   Stack VM (upstream)  :  10.0.0.5
#   rportd API           :  10.0.0.5:38100
#   rportd chisel WS     :  10.0.0.5:38101  (catch-all upstream below)
#   rport-pairing + bins :  10.0.0.5:38102
#   Nuxt UI              :  10.0.0.5:38103
#
# Replace 'rport.example.com' with your DNS name and '10.0.0.5' with the
# LAN IP of your stack VM (or 127.0.0.1 if Caddy and the stack run on
# the same host). Port numbers are the defaults from .env.example.
#
# Caddy upgrades WebSockets transparently and follows X-Forwarded-* by
# default, so the per-location WS hints needed in nginx are unnecessary.

rport.example.com {
	# Logs (optional - drop or redirect as you like).
	log {
		output file /var/log/caddy/rport.example.com.log
		format console
	}

	# rport agents push moderate file sizes; tunnel data goes through chisel
	# (HTTP Upgrade) and is not bound by this limit.
	request_body {
		max_size 10MB
	}

	# ---------- rportd HTTP API ----------
	# `handle` keeps the matched prefix in the upstream request (the API
	# serves under /api/v1/...). Use `handle_path` only when the upstream
	# expects the prefix stripped - see /pairing/ below.
	handle /api/* {
		reverse_proxy 10.0.0.5:38100 # Server  (rportd HTTP API)
	}

	# ---------- Nuxt UI ----------
	handle /ui/* {
		reverse_proxy 10.0.0.5:38103 # UI      (Nuxt)
	}

	# ---------- Static agent binaries (served by pairing) ----------
	handle /binaries/* {
		reverse_proxy 10.0.0.5:38102 # Pairing (binaries mount)
	}

	# ---------- rport-pairing ----------
	# The pairing service serves bare "/", "/update", "/{code}" - strip the
	# /pairing/ prefix before forwarding. The pairing service injects the
	# configured download URLs directly into the rendered scripts via the
	# OPENRPORT_PAIRING_DOWNLOADS_* env vars, so no body rewriting is needed.
	handle_path /pairing/* {
		reverse_proxy 10.0.0.5:38102 # Pairing (HTTP endpoints)
	}

	# ---------- rportd agent connect (chisel WS) ----------
	# Catch-all: agents connect over chisel WS to https://rport.example.com/
	# via HTTP Upgrade, which Caddy forwards transparently to the rportd
	# client port.
	handle {
		reverse_proxy 10.0.0.5:38101 # Server  (chisel WS)
	}
}

# ---------- Notes ----------
# 1. ACME / TLS:
#      For automatic certs from Let's Encrypt, point the
#      rport.example.com A/AAAA record at this Caddy host (203.0.113.20
#      in the example deployment) before reload. To pin a cert manually
#      add `tls /etc/caddy/ssl/fullchain.pem /etc/caddy/ssl/privkey.pem`
#      inside the site block.
# 2. UI:       https://rport.example.com/ui/   (admin / RPORTD_API_PASSWORD)
# 3. API:      https://rport.example.com/api/v1/*
# 4. Binaries: https://rport.example.com/binaries/rport/stable/<arch>.tar.gz
# 5. Pairing:  curl https://rport.example.com/pairing/<7-char-code> | sh
# 6. Reverse-tunnel ports do NOT pass through Caddy. The pool defined by
#    OPENRPORT_TUNNEL_USED_PORTS (default 38200-38400, raw TCP/UDP) must be
#    forwarded directly from the edge firewall to the stack VM (10.0.0.5
#    in this example), NOT to this proxy. Caddy's `layer4` plugin can proxy
#    raw streams but it adds no value here -- the firewall DNAT is simpler.
#    .env.example sets OPENRPORT_TUNNEL_HOST=tunnels.rport.example.com so
#    rportd-generated tunnel links bypass this proxy entirely. Point the
#    tunnels.rport.example.com A record at the same public IP and DNAT the
#    pool ports straight to the stack VM.
